##################################################
### 1. LOTKA-VOLTERRA
##################################################

POST {{host}}/api/models
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "name": "Lotka-Volterra",
  "description": "Drapieznik-ofiara. dx/dt = 1.5*x - 1.0*x*y, dy/dt = -1.0*y + 0.75*x*y",
  "xExpression": "1.5*x - 1.0*x*y",
  "yExpression": "-1.0*y + 0.75*x*y"
}

> {% client.global.set("model_lv", response.body.id); %}

###

POST {{host}}/api/simulations
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "name": "Lotka-Volterra demo",
  "dt": 0.01,
  "stepsCount": 5000,
  "status": "CREATED",
  "dynamicModelId": {{model_lv}}
}

> {% client.global.set("sim_lv", response.body.id); %}

