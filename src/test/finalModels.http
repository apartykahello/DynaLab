Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "name": "Układ liniowy x-y / x+y",
  "description": "Układ liniowy. dx/dt = x - y, dy/dt = x + y",
  "xExpression": "x - y",
  "yExpression": "x + y"
}

